	{waves::tb_top.pipe_if.rx_valid[15:0]}
	} ]
set id [waveform add -signals  {
	waves::tb_top.pipe_if.scrambling_enable
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_compliance[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_data[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_datak[15:0]}
	} ]
