	waves::tb_top.pipe_if.tx_ones_zeroes
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_polarity[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_start_block[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.tx_sync_header[15:0]}
	} ]
