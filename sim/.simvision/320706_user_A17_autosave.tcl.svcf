	{waves::tb_top.pipe_if.rx_lane_aligned[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.rx_margin_status[15:0]}
	} ]
set id [waveform add -signals  {
	{waves::tb_top.pipe_if.rx_polarity_inverted[15:0]}
